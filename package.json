{
  "name": "@reghoul/pm-dashboard",
  "version": "1.0.0",
  "description": "Real-time dashboard for visualizing AI agent project states",
  "bin": {
    "pm-dashboard": "backend/bin/pm-dashboard.js"
  },
  "files": [
    "backend/",
    "frontend/dist/"
  ],
  "scripts": {
    "prepublishOnly": "npm run build --prefix frontend",
    "postinstall": "node backend/bin/pm-dashboard.js init --silent 2>/dev/null || true",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "node backend/server.js"
  },
  "keywords": [
    "openclaw",
    "project-manager",
    "dashboard",
    "ai",
    "websocket",
    "real-time"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw-pm-dashboard.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "ansi-regex": "^5.0.1",
    "ansi-styles": "^4.3.0",
    "chalk": "^4.1.2",
    "cliui": "^8.0.1",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "date-fns": "^2.30.0",
    "emoji-regex": "^8.0.0",
    "escalade": "^3.2.0",
    "get-caller-file": "^2.0.5",
    "has-flag": "^4.0.0",
    "is-fullwidth-code-point": "^3.0.0",
    "lodash": "^4.17.23",
    "require-directory": "^2.1.1",
    "rxjs": "^7.8.2",
    "shell-quote": "^1.8.3",
    "spawn-command": "^0.0.2",
    "string-width": "^4.2.3",
    "strip-ansi": "^6.0.1",
    "supports-color": "^8.1.1",
    "tree-kill": "^1.2.2",
    "tslib": "^2.8.1",
    "wrap-ansi": "^7.0.0",
    "y18n": "^5.0.8",
    "yargs": "^17.7.2",
    "yargs-parser": "^21.1.1"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw-pm-dashboard/issues"
  },
  "homepage": "https://github.com/openclaw/openclaw-pm-dashboard#readme"
}
